      "thumb": "https://cdn.bsky.app/img/feed_thumbnail/plain/did:plc:hovt6k22s64dq63jjmoyibk3/bafkreicxn6xpsevzt5tl7t4vxemm5ft57i2jvg54cf6ox4as5a5ojg6r4u",
