{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "civ",
  "main": "worker.js",
  "compatibility_date": "2026-02-20",
  "compatibility_flags": ["nodejs_compat"],
  // A 1500-tick run grows to ~55k agents and costs ~10-15s of Worker CPU; the sim is bounded
  // (ticks ≤ 1500, mesh ≤ 1200 cells, POP_CAP), so lift the CPU ceiling above the ~default that
  // /api/civ/frames?ticks=1500 was tripping (503). Results are content-addressed + client-cached,
  // so the cost is paid once per distinct run.
  "limits": { "cpu_ms": 120000 },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    // `/` matches a static asset (index.html), which by default is served BEFORE the worker —
    // but the worker must see root requests to 301 legacy dashboard permalinks (/?world=…)
    // to /dash/. Only the root route pays the worker hop; every other asset stays on the
    // asset-first fast path.
    "run_worker_first": ["/"]
  },
  "routes": [
    { "pattern": "civ.mino.mobi", "custom_domain": true }
  ]
}
