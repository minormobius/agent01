// Cloudflare Workers static assets — root directory set to pokemon/
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "poke",
  "compatibility_date": "2026-02-20",
  "assets": {
    "directory": "."
  },
  "routes": [
    { "pattern": "poke.mino.mobi", "custom_domain": true }
  ]
}
