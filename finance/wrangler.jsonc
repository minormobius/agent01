{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fin",
  "main": "worker.js",
  "compatibility_date": "2026-02-20",
  "assets": {
    // Vite builds both apps into dist/:
    //   dist/index.html        -> speculative-feedback playground (root)
    //   dist/pm/index.html     -> personal-finance planning SPA (/pm)
    // The worker owns not-found handling so it can do *subtree-aware* SPA
    // fallback (see worker.js); "none" makes ASSETS return 404 on a miss
    // instead of silently serving the root index for /pm/* deep links.
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "none"
  },
  // Golden rule: the worker named here must own the live custom domain, and
  // the domain must be declared as a custom_domain route. Otherwise a deploy
  // ships green into a stray *.workers.dev and fin.mino.mobi never changes.
  "routes": [
    { "pattern": "fin.mino.mobi", "custom_domain": true }
  ],
  // Experiment store + real-PM snapshots live on the shared atpolls-db
  // (poll/feed/rite/airchat). Tables are prefixed spec_ (migration
  // poll/apps/api/migrations/0031_speclab.sql, applied by deploy-finance.yml).
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "atpolls-db",
      "database_id": "fee2f25a-8b4a-4d46-b245-9d5da93c117d"
    }
  ],
  // Hourly: accrue a real BTC PM snapshot (Coinbase spot + Kalshi implied).
  "triggers": {
    "crons": ["0 * * * *"]
  }
}
