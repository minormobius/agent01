{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "games",
  "main": "worker.js",
  "compatibility_date": "2026-02-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "durable_objects": {
    "bindings": [
      { "name": "ROOM", "class_name": "RoomCoordinator" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RoomCoordinator"]
    }
  ],
  "routes": [
    { "pattern": "games.mino.mobi", "custom_domain": true }
  ]
}
