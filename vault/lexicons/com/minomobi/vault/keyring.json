{
  "lexicon": 1,
  "id": "com.minomobi.vault.keyring",
  "description": "Per-workspace group keyring. Contains the workspace DEK wrapped individually for each member via ECDH + AES-KW.",
  "defs": {
    "main": {
      "type": "record",
      "description": "Group keyring for a workspace.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "members", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable workspace name (encrypted client-side display name stored separately).",
            "maxLength": 256
          },
          "members": {
            "type": "array",
            "description": "List of members with their individually-wrapped DEKs.",
            "items": {
              "type": "ref",
              "ref": "#member"
            },
            "maxLength": 256
          },
          "version": {
            "type": "integer",
            "description": "Incremented on each key rotation.",
            "minimum": 1
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "updatedAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    },
    "member": {
      "type": "object",
      "description": "A group member's wrapped copy of the workspace DEK.",
      "required": ["did", "wrappedDek"],
      "properties": {
        "did": {
          "type": "string",
          "format": "did",
          "description": "Member's DID."
        },
        "wrappedDek": {
          "type": "bytes",
          "description": "Workspace DEK wrapped via ECDH(owner, member) → HKDF → AES-KW.",
          "maxLength": 512
        }
      }
    }
  }
}
