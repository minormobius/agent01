{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "bounty-minomobi",
  "main": "worker.js",
  "compatibility_date": "2026-02-20",
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bounty-board",
      "database_id": "TODO_REPLACE_WITH_D1_DATABASE_ID",
      "migrations_dir": "migrations"
    }
  ]
}
