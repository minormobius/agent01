{
  "lexicon": 1,
  "id": "com.minomobi.airchat.voice",
  "description": "A voice post: an audio blob with a Whisper transcript and optional threading.",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["audio", "text", "createdAt"],
        "properties": {
          "audio": {
            "type": "blob",
            "accept": ["audio/webm", "audio/mp4", "audio/ogg", "audio/wav", "audio/mpeg"],
            "maxSize": 16000000,
            "description": "The voice recording. Browser-encoded, typically webm/opus."
          },
          "text": {
            "type": "string",
            "maxLength": 4000,
            "description": "Transcript. Whisper-generated, possibly user-edited before posting."
          },
          "duration": {
            "type": "number",
            "description": "Duration in seconds."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          },
          "reply": {
            "type": "ref",
            "ref": "#replyRef"
          },
          "lang": {
            "type": "array",
            "items": { "type": "string", "format": "language" },
            "maxLength": 3,
            "description": "BCP-47 language tags Whisper detected."
          }
        }
      }
    },
    "replyRef": {
      "type": "object",
      "required": ["root", "parent"],
      "properties": {
        "root":   { "type": "ref", "ref": "com.atproto.repo.strongRef" },
        "parent": { "type": "ref", "ref": "com.atproto.repo.strongRef" }
      }
    }
  }
}
