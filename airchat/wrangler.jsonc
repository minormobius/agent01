{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "airchat",
  "main": "worker.js",
  "compatibility_date": "2026-02-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "atpolls-db",
      "database_id": "fee2f25a-8b4a-4d46-b245-9d5da93c117d"
    }
  ],
  "routes": [
    { "pattern": "airchat.mino.mobi", "custom_domain": true },
    { "pattern": "yapchat.mino.mobi", "custom_domain": true }
  ]
  // Two custom domains:
  //   airchat.mino.mobi — original deploy URL, kept for back-compat
  //   yapchat.mino.mobi — user-facing rebrand; same worker, same DB,
  //                       same OAuth client (client-metadata.json lives
  //                       at airchat.mino.mobi only)
  //
  // Secrets (set via `npx wrangler secret put <NAME>`):
  //   OPENAI_API_KEY     — Whisper transcription
  //   ADMIN_KEY          — gates /api/airchat/admin/* (whitelist mgmt)
}
